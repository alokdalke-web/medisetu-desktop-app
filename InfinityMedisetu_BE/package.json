{
  "name": "clinic-management-software",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "module": "CommonJS",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "kill-port 5000 && (docker compose -f docker/docker-compose.dev.yml up -d kafka zookeeper redis || echo 'Docker not running, skipping...') && cross-env NODE_ENV=development nodemon",
    "dev:instance": "kill-port 5000 && cross-env NODE_ENV=development nodemon",
    "start:server": "rm -rf dist && npm run build && node dist/server.js",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:migrations:dev": "cross-env NODE_ENV=development drizzle-kit generate --config ./src/drizzle/drizzle.config.ts",
    "db:migrations:staging": "cross-env NODE_ENV=staging drizzle-kit generate --config ./src/drizzle/drizzle.config.ts",
    "db:migrations:prod": "cross-env NODE_ENV=production drizzle-kit generate --config ./src/drizzle/drizzle.config.ts",
    "db:migrate:dev": "cross-env NODE_ENV=development tsx src/drizzle/migrate.ts",
    "db:migrate:staging": "cross-env NODE_ENV=staging tsx src/drizzle/migrate.ts",
    "db:migrate:prod": "cross-env NODE_ENV=production tsx src/drizzle/migrate.ts",
    "db:seed:dev": "cross-env NODE_ENV=development tsx src/drizzle/seed.ts",
    "db:seed:staging": "cross-env NODE_ENV=staging tsx src/drizzle/seed.ts",
    "db:seed:prod": "cross-env NODE_ENV=production tsx src/drizzle/seed.ts",
    "docker:up:dev": "docker compose -f docker/docker-compose.dev.yml up --build",
    "docker:down:dev": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:up:prod": "docker compose -f docker/docker-compose.prod.yml up --build -d",
    "docker:down:prod": "docker compose -f docker/docker-compose.prod.yml down",
    "format": "prettier --write .",
    "prepare": "husky || echo \"Husky not installed, skipping\"",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "lint-staged": {
    "*": [
      "secretlint"
    ],
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-sns": "^3.1066.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@google/genai": "^1.46.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@sparticuz/chromium": "^131.0.1",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.66.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "fs-extra": "^11.3.2",
    "geoip-lite": "^1.4.10",
    "handlebars": "^4.7.9",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.6",
    "otplib": "^13.4.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.7",
    "puppeteer-core": "^24.43.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@swc-node/register": "^1.11.1",
    "@types/compression": "^1.8.1",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/mime-types": "^3.0.1",
    "@types/multer-s3": "^3.0.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.2",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.2.0",
    "fast-check": "^4.8.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "jiti": "^2.6.0",
    "kill-port": "^2.0.1",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "secretlint": "^13.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.45.0"
  }
}
