# Super Admin Credentials
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your_password

# Node environment
NODE_ENV=development

# Server port
PORT=5000
JWT_SECRET_KEY=your_jwt_secret_key
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_ID_IOS=your_google_oauth_client_id_for_ios
GOOGLE_CLIENT_ID_ANDRIOD=your_google_oauth_client_id_for_android
# Use comma-separated IDs if web, iOS, and Android use different Google clients.
GOOGLE_CLIENT_IDS=
FRONT_END_URI=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000


###########################################################################

# Production Database Configuration
PROD_DB_NAME=your_prod_db_name
PROD_DB_USER=your_prod_db_user
PROD_DB_PASS=your_prod_db_password
PROD_DB_HOST=your_prod_db_host
PROD_DB_URL=postgresql://user:password@host:port/dbname

# Development Database Configuration
DEV_DB_NAME=your_dev_db_name
DEV_DB_USER=postgres
DEV_DB_PASS=your_dev_db_password
DEV_DB_HOST=localhost
DEV_DB_PORT=5433
DEV_DB_URL=postgresql://postgres:password@localhost:5433/your_dev_db_name

# Staging Database Configuration (NODE_ENV=staging)
STAGING_DB_NAME=your_staging_db_name
STAGING_DB_USER=your_staging_db_user
STAGING_DB_PASS=your_staging_db_password
STAGING_DB_HOST=your_staging_db_host
STAGING_DB_PORT=5432
STAGING_DB_URL=postgresql://user:password@host:port/your_staging_db_name

###########################################

# SMTP Configuration
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM='Your Name <no-reply@example.com>'

# 1mg API integrations
PRIVATE_KEY_PATH=./private.key
JWT_KID=my-key-1

# Token lifetime in seconds (default 15 minutes)
JWT_EXP_SECONDS=900
# 1mg base URL (sandbox or production)
#ONE_MG_BASE_URL=https://sandbox.1mg.com
ONE_MG_BASE_URL=https://api.1mg.com
ONE_MG_ACCESS_KEY=your_1mg_access_key

# For webhook verification:
WEBHOOK_SHARED_SECRET=your_webhook_secret
KAFKA_BROKERS=localhost:9093
KAFKA_CLIENT_ID=my-app
KAFKA_GROUP_ID=my-app-group
SOCKET_EVENT_TO_KAFKA_PREFIX=socket.events
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173


## Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

## Turnstile Configuration
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Discord Config
DISCORD_TOKEN=your_discord_token
DISCORD_CHANNEL_ID=your_discord_channel_id
CHATWOOT_BASE_URL=http://localhost:5173
CHATWOOT_API_KEY=your_chatwoot_api_key

# AI Model Configuration
MODEL_NAME=gemini-flash-latest
GEMINI_API_KEY=your_gemini_api_key
TESTING=false

# AWS S3 Configuration
AWS_ACCESS_TOKEN=your_aws_access_key
AWS_SECRET_TOKEN=your_aws_secret_key
AWS_REGION=ap-south-1
# Single shared bucket across all environments. Objects are isolated by a
# top-level folder per environment (production/, staging/, development/),
# applied automatically in code based on NODE_ENV (see withEnvPrefix in
# src/configurations/s3/client.ts) — no separate buckets needed.
DEV_AWS_BUCKET_NAME=your_bucket_name
STAGING_AWS_BUCKET_NAME=your_bucket_name
PROD_AWS_BUCKET_NAME=your_bucket_name
AWS_BUCKET_NAME=your_bucket_name

# CloudFront CDN (for public assets like images, logos)
CLOUDFRONT_DOMAIN=your_cloudfront_domain
# Pre-signed URL expiry in seconds (default: 600 = 10 minutes)
PRESIGNED_URL_EXPIRY_SECONDS=600

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# WhatsApp Configuration
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Kickbox Email Verification
KICKBOX_API_KEY=your_kickbox_api_key

# Notifications configuration
ENABLE_NOTIFICATIONS=true

# India DLT (Distributed Ledger Technology) SMS Compliance Configuration
DLT_ENTITY_ID=your_dlt_principal_entity_id_here
DLT_SENDER_ID=MEDISETU

# DLT Template IDs (obtained from carrier DLT portal)
DLT_TEMPLATE_PATIENT_OTP=your_dlt_template_id_for_patient_otp
DLT_TEMPLATE_APPOINTMENT_CONFIRMED=your_dlt_template_id_for_appointment_confirmed
DLT_TEMPLATE_APPOINTMENT_REMINDER=your_dlt_template_id_for_appointment_reminder
DLT_TEMPLATE_APPOINTMENT_NO_SHOW=your_dlt_template_id_for_appointment_no_show
DLT_TEMPLATE_PRESCRIPTION_COMPLETED=your_dlt_template_id_for_prescription_completed
DLT_TEMPLATE_PRESCRIPTION_FOLLOWUP=your_dlt_template_id_for_prescription_followup


# Cloudflare Turnstile secret key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# MFA Configuration
# 32-byte hex key for AES-256-GCM encryption of TOTP secrets
MFA_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_replace_me_with_real_key_00

# Global toggle to enable/disable Razorpay Route split payments.
# If true, payments will split to the clinic's linked accounts. If false, payments fallback to direct central account.
ENABLE_RAZORPAY_ROUTE=true

