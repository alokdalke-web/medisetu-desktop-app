{
  "name": "medi-setu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -b && node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win -c.extraMetadata.main=dist-electron/index.js",
    "publish": "npm run build && electron-builder --win -p always -c.extraMetadata.main=dist-electron/index.js"
  },
  "dependencies": {
    "@adi-prasetyo/react-joyride": "^2.9.3-adp.1",
    "@heroui/react": "^2.8.4",
    "@hookform/resolvers": "^5.2.2",
    "@internationalized/date": "^3.10.0",
    "@marsidev/react-turnstile": "^1.4.1",
    "@react-google-maps/api": "^2.20.8",
    "@react-oauth/google": "^0.13.5",
    "@react-pdf/renderer": "^4.3.1",
    "@reduxjs/toolkit": "^2.9.0",
    "@tailwindcss/vite": "^4.1.13",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@tinymce/tinymce-react": "^6.3.0",
    "@types/react-color": "^3.0.13",
    "axios": "^1.12.2",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "driver.js": "^1.4.0",
    "electron-log": "^5.4.4",
    "framer-motion": "^12.35.1",
    "handlebars": "^4.7.8",
    "history": "^5.3.0",
    "html2pdf.js": "^0.14.0",
    "jscanify": "^1.4.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^1.25.0",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.3.0",
    "react-color": "^2.19.3",
    "react-date-range": "^2.0.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-ga4": "^3.0.1",
    "react-hook-form": "^7.63.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.9.3",
    "react-webcam": "^7.2.0",
    "react-zxing": "^3.0.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.13",
    "tinymce": "^8.3.2",
    "use-debounce": "^10.0.6",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.13",
    "@types/react-date-range": "^1.4.10",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "baseline-browser-mapping": "^2.9.11",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vite-plugin-electron": "^1.1.0",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "build": {
    "appId": "com.infinitymedisetu.app",
    "productName": "Infinity Medi Setu",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "node_modules"
    ],
    "win": {
      "target": [
        "nsis-web"
      ]
    },
    "nsisWeb": {
      "artifactName": "-WebSetup-.",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "alokdalke-web",
        "repo": "medisetu-desktop-app"
      }
    ]
  }
}