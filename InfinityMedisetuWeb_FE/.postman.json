    {
      "name": "App Update",
      "item": [
        {
          "name": "Get App Update Config",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/app-update",
              "host": ["{{base_url}}"],
              "path": ["app-update"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has expected structure', function () {",
                  "  const json = pm.response.json();",
                  "  // Backend returns {} when no config exists, or { data: {...} }",
                  "  if (json.data) {",
                  "    pm.expect(json.data).to.have.property('ios_force_update');",
                  "    pm.expect(json.data).to.have.property('android_force_update');",
                  "    pm.expect(json.data).to.have.property('ios_version');",
                  "    pm.expect(json.data).to.have.property('android_version');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create App Update Config",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ios_force_update\": false,\n  \"android_force_update\": false,\n  \"ios_url\": \"https://apps.apple.com/app/medisetu\",\n  \"android_url\": \"https://play.google.com/store/apps/details?id=com.infinity.medisetu\",\n  \"ios_version\": \"1.0.0\",\n  \"android_version\": \"1.0.0\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/app-update",
              "host": ["{{base_url}}"],
              "path": ["app-update"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response contains config data', function () {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  pm.expect(data).to.have.property('ios_version');",
                  "  pm.expect(data).to.have.property('android_version');",
                  "  pm.expect(data).to.have.property('ios_force_update');",
                  "  pm.expect(data).to.have.property('android_force_update');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update App Update Config",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ios_force_update\": true,\n  \"android_force_update\": true,\n  \"ios_url\": \"https://apps.apple.com/app/medisetu\",\n  \"android_url\": \"https://play.google.com/store/apps/details?id=com.infinity.medisetu\",\n  \"ios_version\": \"2.0.0\",\n  \"android_version\": \"2.0.0\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/app-update",
              "host": ["{{base_url}}"],
              "path": ["app-update"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains updated config', function () {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  pm.expect(data).to.have.property('ios_version');",
                  "  pm.expect(data).to.have.property('android_version');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
